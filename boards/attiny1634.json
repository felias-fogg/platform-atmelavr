{
  "build": {
    "core": "TinyCore",
    "extra_flags": "-DARDUINO_AVR_ATTINY1634 -DLOWERCAL=6",
    "f_cpu": "8000000L",
    "mcu": "attiny1634",
    "variant": "tiny1634_cw"
  },
  "hardware": {
    "oscillator": "internal",
    "uart": "uart0"
  },
  "bootloader": {
    "led_pin": "noled"
  },
  "debug": {
    "pyavrocd_target": "attiny1634",
    "svd_path": "attiny1634.svd"
  },
  "frameworks": [
    "arduino"
  ],
  "name": "Generic ATtiny1634",
  "upload": {
    "extra_flags": "-e",
    "maximum_ram_size": 1024,
    "maximum_size": 16384,
    "protocol": "usbtiny"
  },
  "url": "http://www.atmel.com/devices/ATTINY1634.aspx",
  "vendor": "Atmel"
}