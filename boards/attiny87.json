{
  "build": {
    "core": "TinyCore",
    "extra_flags": "-DARDUINO_AVR_ATTINYX7",
    "f_cpu": "8000000L",
    "mcu": "attiny87",
    "variant": "tinyx7"
  },
  "hardware": {
    "oscillator": "internal",
    "uart": "uart0"
  },
  "bootloader": {
    "led_pin": "noled",
    "uart0_pins": "uart0_rxa0_txa1",
    "speed": 38400
  },
  "debug": {
    "pyavrocd_target": "attiny87",
    "svd_path": "../../../../packages/tool-pyavrocd/pyavrocd-util/svd/attiny87.svd"
  },
  "frameworks": [
    "arduino"
  ],
  "name": "Generic ATtiny87",
  "upload": {
    "extra_flags": "-e",
    "maximum_ram_size": 512,
    "maximum_size": 8192,
    "protocol": "usbtiny"
  },
  "url": "http://www.atmel.com/devices/ATTINY87.aspx",
  "vendor": "Atmel"
}