{
  "build": {
    "core": "arduino",
    "extra_flags": "-DARDUINO_AVR_XMINI_328PB",
    "f_cpu": "16000000L",
    "mcu": "atmega328pb",
    "variant": "pb-variant",
    "hwids": [ "0x03eb",
               "0x2145"
             ]
  },
  "debug": {
    "simavr_target": "atmega328pb",
    "pyavrocd_target": "atmega328pb",
    "svd_path": "../../../../packages/tool-pyavrocd/pyavrocd-util/svd/atmega328pb.svd",
    "tools": {
      "pyavrocd": {
        "init_cmds": [
          "define pio_reset_halt_target",
          "   monitor reset halt",
          "end",
          "define pio_reset_run_target",
          "   monitor reset",
          "   monitor disconnect",
          "   detach",
          "end",
          "target remote $DEBUG_PORT",
          "monitor debugwire enable",
          "$INIT_BREAK",
          "monitor atexit leave",
          "monitor load noinit",
          "load"
        ],
        "load_cmds": "preload" 
      }
    }
  },
  "frameworks": [
    "arduino"
  ],
  "name": "ATmega328PB Xplained Mini",
  "upload": {
    "maximum_ram_size": 2048,
    "maximum_size": 32768,
    "protocol": "xplainedmini_isp",
    "require_upload_port": false,
    "flags": "-e"
  },
  "url": "https://www.microchip.com/en-us/development-tool/ATMEGA328PB-XMINI",
  "vendor": "Microchip"
}