{
  "build": {
    "core": "TinyCore",
    "extra_flags": "-DARDUINO_AVR_AVR_ATTINY828 -DLOWERCAL=6",
    "f_cpu": "8000000L",
    "mcu": "attiny828",
    "variant": "tiny828"
  },
  "hardware": {
    "oscillator": "internal",
    "uart": "uart0"
  },
  "bootloader": {
    "led_pin": "noled"
  },
  "debug": {
    "pyavrocd_target": "attiny828",
    "svd_path": "attiny828.svd"
  },
  "frameworks": [
    "arduino"
  ],
  "name": "Generic ATtiny828",
  "upload": {
    "extra_flags": "-e",
    "maximum_ram_size": 512,
    "maximum_size": 8192,
    "protocol": "usbtiny"
  },
  "url": "http://www.atmel.com/devices/ATTINY828.aspx",
  "vendor": "Atmel"
}