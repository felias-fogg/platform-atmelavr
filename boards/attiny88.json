{
  "build": {
    "core": "TinyCore",
    "extra_flags": "-DARDUINO_AVR_ATTINYX8",
    "f_cpu": "8000000L",
    "mcu": "attiny88",
    "variant": "tinyx8"
  },
  "hardware": {
    "oscillator": "internal"
  },
  "bootloader": {
    "led_pin": "noled",
    "uart_pins": "swio_rxd7_txd6",
    "speed": 38400
  },
  "debug": {
    "pyavrocd_target": "attiny88",
    "svd_path": "attiny88.svd"
  },
  "frameworks": [
    "arduino"
  ],
  "name": "Generic ATtiny88",
  "upload": {
    "extra_flags": "-e",
    "maximum_ram_size": 512,
    "maximum_size": 8192,
    "protocol": "usbtiny"
  },
  "url": "http://www.atmel.com/devices/ATTINY88.aspx",
  "vendor": "Atmel"
}