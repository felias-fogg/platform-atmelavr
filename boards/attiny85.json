{
  "build": {
    "core": "TinyCore",
    "extra_flags": "-DARDUINO_AVR_ATTINYX5",
    "f_cpu": "8000000L",
    "mcu": "attiny85",
    "variant": "tinyx5"
  },
  "hardware": {
    "oscillator": "internal"
  },
  "bootloader": {
    "led_pin": "noled",
    "uart_pins": "swio_rxb1_txb0",
    "speed": 38400
  },
  "debug": {
    "simavr_target": "attiny85",
    "pyavrocd_target": "attiny85",
    "svd_path": "attiny85.svd"
  },
  "frameworks": [
    "arduino"
  ],
  "name": "Generic ATtiny85",
  "upload": {
    "extra_flags": "-e",
    "maximum_ram_size": 512,
    "maximum_size": 8192,
    "protocol": "usbtiny"
  },
  "url": "http://www.atmel.com/devices/ATTINY85.aspx",
  "vendor": "Atmel"
}